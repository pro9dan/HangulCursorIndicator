<Window x:Class="HangulCursorIndicator.Windows.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360"
        SizeToContent="Height"
        MaxHeight="160"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        IsHitTestVisible="False"
        Opacity="0">
    <Border Background="#E6242424"
            CornerRadius="8"
            Padding="14,10"
            SnapsToDevicePixels="True">
        <StackPanel>
            <TextBlock x:Name="MessageText"
                       Foreground="White"
                       FontFamily="Segoe UI, Malgun Gothic"
                       FontSize="15"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Border>
</Window>
