<Window x:Class="HangulCursorIndicator.Windows.MessageInputWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="320"
        Height="52"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Border Background="#F2222222"
            BorderBrush="#664A90E2"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Margin="2,0,0,0"
                       VerticalAlignment="Center"
                       Foreground="#8CFFFFFF"
                       FontFamily="Segoe UI, Malgun Gothic"
                       FontSize="15"
                       IsHitTestVisible="False"
                       Text="&#xBC1C;&#xC2E0;&#xC790;&#xB97C; &#xC54C;&#xC218; &#xC5C6;&#xC2B5;&#xB2C8;&#xB2E4;(&#xC775;&#xBA85;)">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=MessageBox}" Value="">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <TextBox x:Name="MessageBox"
                     Grid.Column="0"
                     BorderThickness="0"
                     Background="Transparent"
                     Foreground="White"
                     CaretBrush="White"
                     FontFamily="Segoe UI, Malgun Gothic"
                     FontSize="15"
                     VerticalContentAlignment="Center"
                     MaxLength="500"
                     KeyDown="MessageBox_KeyDown" />
            <Button Grid.Column="1"
                    Width="24"
                    Height="24"
                    Margin="4,0,0,0"
                    Padding="0"
                    Content="X"
                    Foreground="#E6FFFFFF"
                    Background="Transparent"
                    BorderThickness="0"
                    FontFamily="Segoe UI"
                    FontSize="12"
                    FontWeight="SemiBold"
                    ToolTip="닫기"
                    Click="CloseButton_Click" />
        </Grid>
    </Border>
</Window>
